# Local GemStone install downloaded by the integration-test setup (npm run test:setup).
# Gitignored, but present on disk after running integration tests locally — must never
# be bundled into the .vsix (it is ~1GB and contains example private keys).
client/tmp/**

# Contributor tooling and docs — not part of the shipped extension.
.github/**
acceptance/**
scripts/**
.dockerignore
CLAUDE.md
**/CLAUDE.md

docs/**
!docs/mcp-server.md
!docs/windows-wsl.md
!docs/formatter.md

# Server-side Smalltalk source (the refactoring engine, its vendored AST, tests,
# and build tooling). This is source-of-truth, not runtime: the extension files
# the *generated* payloads under resources/refactoring/ (ast-core.gs, compat.gs,
# engine.gs, manifest.gs, refactoring-loader.gs) into a stone and never reads
# gs-src/ itself. Mirrors how client/src, server/src, etc. are excluded.
gs-src/**

node_modules/**
client/node_modules/**
server/node_modules/**
mcp-server/node_modules/**
!node_modules/koffi/package.json
!node_modules/koffi/index.js
!node_modules/koffi/indirect.js
!node_modules/koffi/index.d.ts
!node_modules/koffi/LICENSE.txt
!node_modules/koffi/build/**

client/src/**
# listFilter.js, methodListView.js, debuggerView.js, and enhancedInspectorColumns.js are read at runtime
# via fs.readFileSync and injected into webviews as <script> tags. They must ship as standalone files —
# they cannot be compiled into the bundle. (debuggerView.js is read at module load by debuggerPanel.ts,
# which extension.ts imports eagerly, so omitting it here makes loading the packaged extension.js throw
# and activation fail entirely. enhancedInspectorColumns.js is likewise read at module load by
# enhancedInspector.ts.)
!client/src/listFilter.js
!client/src/methodListView.js
!client/src/debuggerView.js
!client/src/enhancedInspectorColumns.js
!client/src/browserColumnResize.js
!client/src/renameInstVarPanelView.js
server/src/**
mcp-server/src/**

client/out/**
!client/out/extension.js
server/out/**
!server/out/server.js
mcp-server/out/**
!mcp-server/out/index.js

tsconfig.base.json
client/tsconfig.json
server/tsconfig.json
mcp-server/tsconfig.json
**/*.tsbuildinfo
client/package.json
server/package.json
mcp-server/package.json
esbuild.mjs
package-lock.json
**/*.ts
