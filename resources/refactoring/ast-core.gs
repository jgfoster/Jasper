method: RBParseTreeSearcher
addArgumentRule: aParseTreeRule
	argumentSearches add: aParseTreeRule.
	aParseTreeRule owner: self
%

category: 'accessing'
method: RBParseTreeSearcher
addArgumentRules: ruleCollection
	ruleCollection do: [:each | self addArgumentRule: each]
